<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Links - Osm-it</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
  <style>
    :root {
      --cream: #ede8e1;
      --white: #faf8f5;
      --sand: #c9a98a;
      --sand-light: #e8d8c6;
      --sand-mid: #d6bfa6;
      --brown: #7b5c3c;
      --brown-dark: #5a4028;
      --text: #2a1e10;
      --text-muted: #9a8470;
      --border: #dfd0bc;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'DM Sans', sans-serif; background: var(--cream); min-height: 100vh; padding: 20px 12px; }
    .container { max-width: 900px; margin: 0 auto; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 12px; }
    .page-logo { font-family: 'DM Serif Display', serif; font-size: 20px; color: var(--text); }
    .header-actions { display: flex; gap: 8px; }
    .btn-new { font-family: 'DM Sans', sans-serif; font-size: 11px; padding: 8px 14px; border-radius: 6px; border: none; background: var(--brown); color: #fff; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
    .btn-new:hover { background: var(--brown-dark); }
    .search-box { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
    .search-input { flex: 1; min-width: 150px; padding: 10px 12px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 13px; font-family: 'DM Sans', sans-serif; background: var(--white); color: var(--text); }
    .search-input:focus { outline: none; border-color: var(--sand); }
    .page-title { font-family: 'DM Serif Display', serif; font-size: 18px; color: var(--text); margin-bottom: 16px; }
    .links-list { background: var(--white); border-radius: 12px; box-shadow: 0 4px 20px rgba(80,50,20,0.08); overflow: hidden; }
    .link-item { display: flex; flex-wrap: wrap; gap: 10px; padding: 12px 14px; border-bottom: 1px solid var(--border); transition: background 0.15s; position: relative; }
    .link-item:last-child { border-bottom: none; }
    .link-item:hover { background: #faf8f5; }
    .link-globe { width: 28px; height: 28px; border-radius: 6px; background: var(--sand-light); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: var(--brown); }
    .link-info { flex: 1; min-width: 0; flex-basis: calc(100% - 42px); }
    .link-original { font-size: 11px; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .link-short { font-size: 10px; color: var(--brown); font-weight: 500; margin-top: 2px; }
    .link-meta { display: flex; gap: 16px; margin-left: 42px; }
    .meta-item { text-align: left; min-width: auto; }
    .meta-value { font-size: 12px; font-weight: 600; color: var(--text); }
    .meta-label { font-size: 8px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px; }
    .link-actions { display: flex; gap: 6px; flex-wrap: wrap; }
    .btn-copy-small { font-family: 'DM Sans', sans-serif; font-size: 9px; padding: 5px 10px; border: 1.5px solid var(--border); border-radius: 5px; background: transparent; color: var(--text); cursor: pointer; display: flex; align-items: center; gap: 3px; text-decoration: none; }
    .btn-copy-small:hover { background: var(--sand-light); }
    .btn-copy-small.copied { background: var(--brown); border-color: var(--brown); color: #fff; }
    .pagination { display: flex; justify-content: center; gap: 6px; margin-top: 20px; flex-wrap: wrap; }
    .page-btn { font-family: 'DM Sans', sans-serif; font-size: 11px; padding: 6px 10px; border: 1.5px solid var(--border); border-radius: 6px; background: var(--white); color: var(--text); cursor: pointer; text-decoration: none; }
    .page-btn:hover { background: var(--sand-light); }
    .page-btn.active { background: var(--brown); border-color: var(--brown); color: #fff; }
    .page-btn.disabled { opacity: 0.5; cursor: not-allowed; }
    .empty-state { text-align: center; padding: 40px 16px; color: var(--text-muted); }
    .total-count { font-size: 12px; color: var(--text-muted); margin-bottom: 12px; }
    @media (min-width: 600px) { body { padding: 32px 20px; } .page-header { margin-bottom: 24px; } .page-logo { font-size: 22px; } .btn-new { font-size: 12px; padding: 10px 18px; gap: 6px; } .search-box { gap: 12px; margin-bottom: 20px; } .search-input { padding: 12px 16px; } .page-title { font-size: 20px; margin-bottom: 20px; } .link-item { padding: 14px 16px; gap: 12px; } .link-globe { width: 32px; height: 32px; border-radius: 8px; } .link-info { flex-basis: auto; } .link-original { font-size: 12px; max-width: 200px; } .link-short { font-size: 11px; } .link-meta { gap: 20px; margin-left: 0; } .meta-value { font-size: 13px; } .meta-label { font-size: 9px; } .link-actions { gap: 8px; } .btn-copy-small { font-size: 10px; padding: 6px 12px; gap: 4px; } .pagination { gap: 8px; margin-top: 24px; } .page-btn { font-size: 12px; padding: 8px 14px; } }
  </style>
</head>
<body>
  <div class="container">
    <div class="page-header">
      <span class="page-logo">Osm-it</span>
      <a href="/short?password=<%= password %>" class="btn-new">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Link
      </a>
    </div>

    <h2 class="page-title">Your Recent Osm-it-URLs</h2>

    <form method="GET" class="search-box">
      <input type="hidden" name="password" value="<%= password %>">
      <input type="text" name="search" class="search-input" placeholder="Search by code..." value="<%= search %>">
      <button type="submit" class="btn-new">Search</button>
      <% if (search) { %>
        <a href="?password=<%= password %>" class="btn-new" style="background: var(--text-muted);">Clear</a>
      <% } %>
    </form>

    <div class="total-count">Total: <%= totalUrls %> links</div>

    <% if (urls.length === 0) { %>
      <div class="links-list">
        <div class="empty-state">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          <p><%= search ? 'No links found for "' + search + '"' : 'No links created yet' %></p>
          <a href="/short?password=<%= password %>" style="color: var(--brown); margin-top: 12px; display: inline-block;">Create your first link!</a>
        </div>
      </div>
    <% } else { %>
      <div class="links-list">
        <% urls.forEach(function(url, index) { %>
        <div class="link-item">
          <div class="link-globe">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <div class="link-info">
            <div class="link-original" title="<%= url.original_url %>">
              <%= url.original_url %>
            </div>
            <div class="link-short"><%= url.short_url %></div>
          </div>
          <div class="link-meta">
            <div class="meta-item">
              <div class="meta-value"><%= url.clicks.toLocaleString() %></div>
              <div class="meta-label">Clicks</div>
            </div>
            <div class="meta-item">
              <div class="meta-value"><%= new Date(url.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></div>
              <div class="meta-label">Created</div>
            </div>
          </div>
          <div class="link-actions">
            <button class="btn-copy-small" onclick="copyLink('<%= url.short_url %>', this)">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy
            </button>
            <a href="/stats?code=<%= url.short_code %>&password=<%= password %>" class="btn-copy-small">Stats</a>
          </div>
        </div>
        <% }); %>
      </div>

      <% if (totalPages > 1) { %>
      <div class="pagination">
        <a href="?password=<%= password %>&search=<%= search %>&page=<%= currentPage - 1 %>" class="page-btn <%= currentPage <= 1 ? 'disabled' : '' %>">← Prev</a>
        <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
          <a href="?password=<%= password %>&search=<%= search %>&page=<%= i %>" class="page-btn <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
        <% } %>
        <a href="?password=<%= password %>&search=<%= search %>&page=<%= currentPage + 1 %>" class="page-btn <%= currentPage >= totalPages ? 'disabled' : '' %>">Next →</a>
      </div>
      <% } %>
    <% } %>
  </div>

  <script>
    function copyLink(url, btn) {
      navigator.clipboard.writeText(url).then(() => {
        btn.classList.add('copied');
        btn.innerHTML = '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
        setTimeout(() => {
          btn.classList.remove('copied');
          btn.innerHTML = '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy';
        }, 2000);
      });
    }
  </script>
</body>
</html>
